# ── Database ──────────────────────────────────────────────
POSTGRES_USER=forecast
POSTGRES_PASSWORD=forecast
POSTGRES_DB=forecast
DATABASE_URL=postgresql+asyncpg://forecast:forecast@localhost:5432/forecast

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Application ───────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── AskNews (preferred for forecasting — time-gated, no outcome leakage) ──
# Option 1: single API key (simpler)
ASKNEWS_API_KEY=your-asknews-api-key
# Option 2: OAuth2 client credentials
# ASKNEWS_CLIENT_ID=your-asknews-client-id
# ASKNEWS_CLIENT_SECRET=your-asknews-client-secret

# ── Search provider: "asknews", "exa", or "auto" (default) ──
# SEARCH_PROVIDER=auto

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
